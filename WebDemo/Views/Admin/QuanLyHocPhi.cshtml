@model IEnumerable<WebDemo.Models.HocPhi>
@{
    ViewBag.Title = "Quản lý Học phí";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<h1 class="h3 fw-bold mb-4">Quản lý Học phí</h1>

<form method="get" class="mb-4">
    <div class="input-group shadow-sm" style="max-width: 500px;">
        <input type="text" name="searchString" class="form-control" placeholder="Tìm kiếm theo tên hoặc SĐT..." value="@Request.QueryString["searchString"]">
        <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i> Tìm kiếm</button>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã HP</th>
                        <th>Học viên</th>
                        <th>Khóa học</th>
                        <th>Số tiền</th>
                        <th>Ngày đóng</th>
                        <th>Trạng thái</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr id="row_@item.MaHocPhi">
                            <td>#@item.MaHocPhi</td>
                            <td>
                                <strong>@item.HocSinh.NguoiDung.HoTen</strong><br />
                                <small class="text-muted">@item.HocSinh.NguoiDung.SoDienThoai</small>
                            </td>
                            <td>@item.KhoaHoc.TenKhoaHoc</td>
                            <td class="fw-bold text-primary">@item.SoTien.ToString("N0")₫</td>
                            <td id="ngay_@item.MaHocPhi">
                                @(item.NgayDong.HasValue ? item.NgayDong.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                            </td>
                            <td id="status_@item.MaHocPhi">
                                @if (item.TrangThai == "DaDong")
                                {
                                    <span class="badge bg-success">Đã đóng</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Chưa đóng</span>
                                }
                            </td>
                            <td>
                                <div id="action_@item.MaHocPhi">
                                    @if (item.TrangThai != "DaDong")
                                    {
                                        <button class="btn btn-sm btn-outline-success" onclick="ThuTien(@item.MaHocPhi)">
                                            <i class="bi bi-cash-coin"></i> Thu tiền
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-secondary" disabled title="Đã hoàn tất">
                                            <i class="bi bi-check2-all"></i>
                                        </button>
                                        <a href="#" class="btn btn-sm btn-outline-info" title="In hóa đơn" onclick="alert('Tính năng in đang phát triển!'); return false;">
                                            <i class="bi bi-printer"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">Không tìm thấy dữ liệu học phí nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function ThuTien(id) {
        if (confirm('Xác nhận học viên này đã đóng tiền?')) {
            $.ajax({
                url: '/Admin/XacNhanThuTien',
                type: 'POST',
                data: { maHocPhi: id },
                success: function (res) {
                    if (res.success) {
                        alert(res.message);
                        // Cập nhật giao diện ngay lập tức (DOM Update)
                        $('#status_' + id).html('<span class="badge bg-success">Đã đóng</span>');

                        var now = new Date();
                        var dateStr = now.toLocaleDateString('vi-VN') + ' ' + now.toLocaleTimeString('vi-VN');
                        $('#ngay_' + id).text(dateStr);

                        // Đổi nút bấm thành nút In hóa đơn
                        var btnHtml = '<button class="btn btn-sm btn-secondary me-1" disabled><i class="bi bi-check2-all"></i></button>';
                        btnHtml += '<a href="#" class="btn btn-sm btn-outline-info" onclick="alert(\'Tính năng in đang phát triển!\'); return false;"><i class="bi bi-printer"></i></a>';
                        $('#action_' + id).html(btnHtml);
                    } else {
                        alert(res.message);
                    }
                },
                error: function () {
                    alert("Lỗi kết nối server.");
                }
            });
        }
    }
</script>