@model WebDemo.Models.HocSinh
@{
    ViewBag.Title = "Thêm Học viên mới";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<h1 class="h3 fw-bold mb-4">Thêm Học viên mới</h1>

<div class="card border-0 shadow-sm">
    <div class="card-body">

        @using (Html.BeginForm("ThemHocVien", "Admin", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
            }

            <h5 class="card-title mb-3">Thông tin tài khoản</h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label required">Họ và tên</label>
                    <input type="text" name="nguoiDung.HoTen" class="form-control" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label required">Email</label>
                    <input type="email" name="nguoiDung.Email" class="form-control" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Số điện thoại</label>
                    <input type="tel" name="nguoiDung.SoDienThoai" class="form-control">
                </div>
                <div class="col-md-6">
                    <label class="form-label">Địa chỉ</label>
                    <input type="text" name="nguoiDung.DiaChi" class="form-control">
                </div>
            </div>

            <hr class="my-4">

            <h5 class="card-title mb-3">Thông tin học viên</h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Ngày sinh</label>
                    <input type="date" name="hocSinh.NgaySinh" class="form-control">
                </div>
                <div class="col-md-6">
                    <label class="form-label">Giới tính</label>
                    <select name="hocSinh.GioiTinh" class="form-select">
                        <option value="">Chọn...</option>
                        <option value="Nam">Nam</option>
                        <option value="Nu">Nữ</option>
                        <option value="Khac">Khác</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Chọn Phụ huynh (nếu có)</label>
                    @Html.DropDownList("hocSinh.MaPhuHuynh", ViewBag.DanhSachPhuHuynh as SelectList, "(Không có)", new { @class = "form-select" })
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary btn-lg">Lưu học viên</button>
                <a href="@Url.Action("QuanLyHocVien")" class="btn btn-outline-secondary btn-lg">Hủy</a>
            </div>
        }
    </div>
</div>