@model IEnumerable<WebDemo.Models.HocVienViewModel>
@{
    ViewBag.Title = "Quản lý Học viên";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold m-0">Quản lý Học viên</h1>
    <a href="@Url.Action("ThemHocVien", "Admin")" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Thêm học viên mới
    </a>
</div>
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th>Ngày sinh</th>
                        <th>Phụ huynh</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr id="row-hv-@item.MaHocSinh">
                            <td>@Html.DisplayFor(modelItem => item.HoTen)</td>
                            <td>@Html.DisplayFor(modelItem => item.Email)</td>
                            <td>@(item.NgaySinh.HasValue ? item.NgaySinh.Value.ToString("dd/MM/yyyy") : "")</td>
                            <td>@Html.DisplayFor(modelItem => item.TenPhuHuynh)</td>
                            <td>
                                <button class="btn btn-sm btn-outline-secondary btn-sua-hv"
                                        title="Sửa"
                                        data-bs-toggle="modal"
                                        data-bs-target="#suaHocVienModal"
                                        data-id="@item.MaHocSinh">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger btn-xoa-hv"
                                        title="Xóa"
                                        data-id="@item.MaHocSinh">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="suaHocVienModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Chỉnh sửa Học viên</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <input type="hidden" id="editHv_MaHocSinh" name="hocSinh.MaHocSinh" />

                <h6 class="text-secondary">Thông tin tài khoản</h6>
                <div class="row g-3 mb-3">
                    <div class="col-md-6"><label class="form-label">Họ tên</label><input type="text" id="editHv_HoTen" name="nguoiDung.HoTen" class="form-control" required></div>
                    <div class="col-md-6"><label class="form-label">Email</label><input type="email" id="editHv_Email" name="nguoiDung.Email" class="form-control" required></div>
                    <div class="col-md-6"><label class="form-label">Số điện thoại</label><input type="tel" id="editHv_SoDienThoai" name="nguoiDung.SoDienThoai" class="form-control"></div>
                    <div class="col-md-6"><label class="form-label">Địa chỉ</label><input type="text" id="editHv_DiaChi" name="nguoiDung.DiaChi" class="form-control"></div>
                </div>

                <hr>
                <h6 class="text-secondary">Thông tin học viên</h6>
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">Ngày sinh</label><input type="date" id="editHv_NgaySinh" name="hocSinh.NgaySinh" class="form-control"></div>
                    <div class="col-md-6">
                        <label class="form-label">Giới tính</label>
                        <select id="editHv_GioiTinh" name="hocSinh.GioiTinh" class="form-select">
                            <option value="">Chọn...</option>
                            <option value="Nam">Nam</option>
                            <option value="Nu">Nữ</option>
                            <option value="Khac">Khác</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phụ huynh (nếu có)</label>
                        <select id="editHv_MaPhuHuynh" name="hocSinh.MaPhuHuynh" class="form-select"></select>
                    </div>
                </div>

            </div>
            <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Đóng</button><button type="button" id="btnLuuSuaHocVien" class="btn btn-primary">Lưu thay đổi</button></div>
        </div>
    </div>
</div>


@section scripts {
    <script>
        $(document).ready(function () {
            // -------- 1. XỬ LÝ NÚT XÓA HV --------
            $('.btn-xoa-hv').on('click', function (e) {
                e.preventDefault();
                var idHocVien = $(this).data('id');
                if (confirm('Bạn có chắc muốn xóa học viên này không?')) {
                    $.ajax({
                        url: '@Url.Action("XoaHocVien", "Admin")', type: 'POST', data: { id: idHocVien },
                        success: function (result) {
                            if (result.success) { $('#row-hv-' + idHocVien).remove(); alert(result.message); } else { alert(result.message); }
                        }, error: function () { alert('Không thể kết nối đến máy chủ.'); }
                    });
                }
            });

            // -------- 2. (MỚI) XỬ LÝ NÚT SỬA HV --------
            $('.btn-sua-hv').on('click', function () {
                var idHocVien = $(this).data('id');
                $.ajax({
                    url: '@Url.Action("SuaHocVien", "Admin")' + '/' + idHocVien,
                    type: 'GET',
                    success: function (response) {
                        var hv = response.data;
                        // Đổ data vào modal
                        $('#editHv_MaHocSinh').val(hv.MaHocSinh);
                        $('#editHv_HoTen').val(hv.HoTen);
                        $('#editHv_Email').val(hv.Email);
                        $('#editHv_SoDienThoai').val(hv.SoDienThoai);
                        $('#editHv_DiaChi').val(hv.DiaChi);
                        $('#editHv_NgaySinh').val(hv.NgaySinh);
                        $('#editHv_GioiTinh').val(hv.GioiTinh);

                        // Cập nhật danh sách dropdown phụ huynh
                        var phSelect = $('#editHv_MaPhuHuynh');
                        phSelect.empty(); // Xóa list cũ
                        phSelect.append($('<option>', { value: '', text: '(Không có)' })); // Thêm option mặc định
                        $.each(response.phuHuynhList, function (i, ph) {
                            phSelect.append($('<option>', {
                                value: ph.MaNguoiDung,
                                text: ph.HoTen
                            }));
                        });
                        // Set giá trị đã chọn
                        phSelect.val(hv.MaPhuHuynh);

                    }, error: function () { alert("Không thể tải dữ liệu học viên."); }
                });
            });

            // Khi bấm nút "Lưu thay đổi" trong Modal Sửa HV
            $('#btnLuuSuaHocVien').on('click', function () {
                var hvData = {
                    nguoiDung: {
                        HoTen: $('#editHv_HoTen').val(),
                        Email: $('#editHv_Email').val(),
                        SoDienThoai: $('#editHv_SoDienThoai').val(),
                        DiaChi: $('#editHv_DiaChi').val()
                    },
                    hocSinh: {
                        MaHocSinh: $('#editHv_MaHocSinh').val(),
                        NgaySinh: $('#editHv_NgaySinh').val() || null,
                        GioiTinh: $('#editHv_GioiTinh').val(),
                        MaPhuHuynh: $('#editHv_MaPhuHuynh').val() || null
                    }
                };
                $.ajax({
                    url: '@Url.Action("SuaHocVien", "Admin")',
                    type: 'POST',
                    data: hvData,
                    success: function (result) {
                        if (result.success) {
                            alert(result.message);
                            // Tải lại trang để cập nhật (cách đơn giản nhất)
                            location.reload();
                        } else { alert(result.message); }
                    }, error: function () { alert("Lưu thất bại."); }
                });
            });

        });
    </script>
}