@model WebDemo.Models.ChiTietLopHocViewModel
@{
    ViewBag.Title = "Chi tiết Lớp học";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 fw-bold m-0">@Model.LopHoc.TenLop</h1>
        <span class="text-secondary">@Model.KhoaHoc.TenKhoaHoc | GV: @Model.TenGiaoVien</span>
    </div>
    <a href="@Url.Action("Index", "Admin")" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-3">Thêm học sinh vào lớp</h5>
                @using (Html.BeginForm("ThemHocSinhVaoLop", "Admin", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="maLop" value="@Model.LopHoc.MaLop" />

                    <div class="mb-3">
                        <label class="form-label">Chọn học sinh chưa có trong lớp</label>
                        @Html.DropDownList("maHocSinhCanThem", Model.DSHocSinhChuaCo, "Chọn học sinh...", new { @class = "form-select" })
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Thêm vào lớp</button>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-3">Danh sách học sinh (Tổng: @Model.DSHocSinhDaCo.Count)</h5>
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Họ tên</th>
                                <th>Email</th>
                                <th>Ngày đăng ký</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var hs in Model.DSHocSinhDaCo)
                            {
                                <tr id="row-hv-@hs.MaHocSinh">
                                    <td>@hs.HoTen</td>
                                    <td>@hs.Email</td>
                                    <td>@hs.NgayDangKy.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-danger btn-xoa-hv-lop"
                                                data-mahocsinh="@hs.MaHocSinh"
                                                data-malop="@Model.LopHoc.MaLop"
                                                title="Xóa khỏi lớp">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                            @if (!Model.DSHocSinhDaCo.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-secondary">Lớp này chưa có học sinh nào.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            $('.btn-xoa-hv-lop').on('click', function (e) {
                e.preventDefault();

                // Lấy 2 khóa
                var idHocVien = $(this).data('mahocsinh');
                var idLop = $(this).data('malop');

                if (confirm('Bạn có chắc muốn xóa học sinh này khỏi lớp?')) {
                    $.ajax({
                        url: '@Url.Action("XoaHocSinhKhoiLop", "Admin")',
                        type: 'POST',
                        // Gửi 2 khóa
                        data: {
                            maHocSinh: idHocVien,
                            maLop: idLop
                        },
                        success: function (result) {
                            if (result.success) {
                                // Xóa hàng bằng id của học viên
                                $('#row-hv-' + idHocVien).remove();
                                alert(result.message);
                                // Tải lại trang để cập nhật dropdown (Cách đơn giản nhất)
                                location.reload();
                            } else {
                                alert(result.message);
                            }
                        },
                        error: function () {
                            alert('Không thể kết nối đến máy chủ.');
                        }
                    });
                }
            });
        });
    </script>
}