<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title — EnglishCenter</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        :root {
            --brand: #0d6efd;
        }

        body {
            font-family: Inter, system-ui, -apple-system, sans-serif;
        }

        .footer {
            background: #0b1220;
            color: #b9c0d0;
        }

            .footer a {
                color: #e9ecef;
                text-decoration: none;
            }

                .footer a:hover {
                    text-decoration: underline;
                }

        /* Một số style cho phần nội dung con */
        .section-title {
            font-weight: 700;
            letter-spacing: .2px;
        }

        .price {
            font-size: 2rem;
            font-weight: 700;
        }

        .required:after {
            content: "*";
            color: #dc3545;
            margin-left: .25rem;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">EnglishCenter<span class="text-primary">.</span></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <div class="ms-lg-3 d-flex gap-2">
                    <a href="@Url.Action("Login", "Account")" class="btn btn-outline-primary">Đăng nhập</a>
                    <a href="#dangky-form" class="btn btn-primary">Đăng ký ngay</a>
                </div>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="footer py-5 mt-auto">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-6">
                    <h5 class="text-white">EnglishCenter.</h5>
                    <p class="small mb-0">© 2025 — Trung tâm tiếng Anh. 123 Nguyễn Văn Cừ, Q.5, TP.HCM</p>
                </div>
                <div class="col-md-6">
                    <div class="d-flex gap-3 justify-content-md-end">
                        <a href="#">Về chúng tôi</a>
                        <a href="#">Liên hệ</a>
                        <a href="#">Điều khoản</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("scripts", required: false)
</body>
</html>