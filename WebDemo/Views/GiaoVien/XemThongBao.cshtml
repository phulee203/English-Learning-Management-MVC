@model IEnumerable<WebDemo.Models.ThongBaoViewModel>
@{
    ViewBag.Title = "Thông báo Giáo viên";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<h1 class="h3 fw-bold mb-4">Thông báo nội bộ</h1>

<div class="row g-3">
    @foreach (var item in Model)
    {
        <div class="col-12">
            <div class="card shadow-sm border-0 @(item.DaDoc ? "" : "border-start border-5 border-warning")">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title fw-bold m-0">
                            @if (!item.DaDoc)
                            {
                                <span class="badge bg-warning text-dark me-2">Mới</span>
                            }
                            @item.TieuDe
                        </h5>
                        <small class="text-muted">
                            <i class="bi bi-calendar3"></i> @(item.NgayGui.HasValue ? item.NgayGui.Value.ToString("dd/MM/yyyy HH:mm") : "")
                        </small>
                    </div>
                    <h6 class="card-subtitle mb-3 text-muted small">Từ: @item.NguoiGui (Ban Quản Trị)</h6>
                    <div class="p-3 bg-light rounded text-secondary">
                        @item.NoiDung
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <p class="text-muted">Chưa có thông báo nào.</p>
        </div>
    }
</div>