@model List<WebDemo.Models.DiemViewModel>
@{
    ViewBag.Title = "Nhập điểm - " + ViewBag.TenLop;
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    int maLop = ViewBag.MaLop;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold m-0">Nhập điểm: @ViewBag.TenLop</h1>
    <a href="@Url.Action("LopCuaToi", "GiaoVien")" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách lớp
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body">

        @using (Html.BeginForm("LuuDiem", "GiaoVien", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="maLop" value="@maLop" />

            <div class="table-responsive">
                <table class="table align-middle table-hover">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" style="width: 50px;">STT</th>
                            <th scope="col">Mã HS</th>
                            <th scope="col">Họ tên</th>
                            <th scope="col" style="width: 150px;">Điểm giữa kỳ</th>
                            <th scope="col" style="width: 150px;">Điểm cuối kỳ</th>
                            <th scope="col">Nhận xét</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            <tr>
                                <td>@(i + 1)</td>
                                <td>
                                    <input type="hidden" name="listDiem[@i].MaHocSinh" value="@Model[i].MaHocSinh" />
                                    HS@(Model[i].MaHocSinh)
                                </td>
                                <td class="fw-bold">@Model[i].HoTen</td>
                                <td>
                                    <input type="number" step="0.1" min="0" max="10" class="form-control"
                                           name="listDiem[@i].DiemGiuaKy" value="@Model[i].DiemGiuaKy" placeholder="-" />
                                </td>
                                <td>
                                    <input type="number" step="0.1" min="0" max="10" class="form-control"
                                           name="listDiem[@i].DiemCuoiKy" value="@Model[i].DiemCuoiKy" placeholder="-" />
                                </td>
                                <td>
                                    <input type="text" class="form-control"
                                           name="listDiem[@i].NhanXet" value="@Model[i].NhanXet" placeholder="Nhập nhận xét..." />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            if (Model.Count > 0)
            {
                <div class="text-end mt-3">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-save"></i> Lưu bảng điểm
                    </button>
                </div>
            }
            else
            {
                <div class="alert alert-warning text-center">Lớp này chưa có học sinh nào.</div>
            }
        }
    </div>
</div>