@model IEnumerable<WebDemo.Models.ThongBaoViewModel>
@{
    ViewBag.Title = "Thông báo của tôi";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<h1 class="h3 fw-bold mb-4">Thông báo từ Trung tâm</h1>

<div class="row g-3">
    @foreach (var item in Model)
    {
        <div class="col-12">
            <div class="card shadow-sm border-0 @(item.DaDoc ? "" : "border-start border-5 border-primary")">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title fw-bold m-0">
                            @if (!item.DaDoc)
                            {
                                <span class="badge bg-danger me-2">Mới</span>
                            }
                            @item.TieuDe
                        </h5>
                        <small class="text-muted">
                            <i class="bi bi-clock"></i> @(item.NgayGui.HasValue ? item.NgayGui.Value.ToString("dd/MM/yyyy HH:mm") : "")
                        </small>
                    </div>
                    <h6 class="card-subtitle mb-3 text-muted small">Người gửi: @item.NguoiGui</h6>
                    <p class="card-text bg-light p-3 rounded">
                        @item.NoiDung
                    </p>
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <img src="https://cdn-icons-png.flaticon.com/512/4076/4076432.png" width="80" class="mb-3 opacity-50" />
            <p class="text-muted">Hiện chưa có thông báo nào.</p>
        </div>
    }
</div>